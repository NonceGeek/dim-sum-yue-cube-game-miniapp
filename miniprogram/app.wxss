/**app.wxss - 科技蓝紫配色方案**/

/* ============================================
   Design System - Tech Blue Purple Theme
   ============================================ */

/* 基础容器样式 */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

/* 全局字体 */
page,
view,
text {
  font-family:
    -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto,
    "Helvetica Neue", Arial, sans-serif;
}

.nav {
  text-align: center;
}

/* ============================================
   Light Mode - CSS Variables
   ============================================ */
page {
  /* 主色调 */
  --primary: #4a7cf3;
  --primary-light: #6b93f5;
  --primary-dark: #3566d9;
  --secondary: #7c5cff;
  --secondary-light: #9178ff;

  /* 渐变 */
  --gradient-primary: linear-gradient(135deg, #4a7cf3 0%, #7c5cff 100%);
  --gradient-button: linear-gradient(135deg, #4a7cf3 0%, #6b93f5 100%);
  --gradient-subtitle: linear-gradient(
    to right,
    rgba(74, 124, 243, 0.45) 0%,
    rgba(124, 92, 255, 0.45) 50%,
    transparent 100%
  );
  --gradient-primary-start: #4a7cf3;
  --gradient-primary-end: #7c5cff;

  /* 背景色 */
  --bg-page: #f5f7fa;
  --bg-card: #ffffff;
  --bg-input: #f8fafc;
  --bg-elevated: #ffffff;

  /* 文字色 */
  --text-primary: #1a1f36;
  --text-secondary: #64748b;
  --text-muted: #94a3b8;
  --text-inverse: #ffffff;

  /* 边框 */
  --border-color: #e2e8f0;
  --border-light: #f1f5f9;

  /* 状态色 */
  --success: #10b981;
  --warning: #f59e0b;
  --danger: #ef4444;
  --info: #3b82f6;

  /* 阴影 */
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
  --shadow-md:
    0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
  --shadow-lg:
    0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
  --shadow-primary: 0 4px 14px rgba(74, 124, 243, 0.25);

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;

  /* TDesign 覆盖 */
  --td-bg-color-container: var(--bg-card);
  --td-bg-color-page: var(--bg-page);
  --td-text-color-primary: var(--text-primary);
  --td-text-color-secondary: var(--text-secondary);
  --td-text-color-placeholder: var(--text-muted);
  --td-border-color: var(--border-color);
  --td-brand-color: var(--primary);
  --td-tab-bar-color: var(--text-secondary);
  --td-tab-bar-active-color: var(--primary);
  --td-tab-bar-item-color: var(--text-muted);
  --td-tab-bar-item-active-color: var(--primary);
  --td-font-family:
    -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto,
    sans-serif;

  background-color: var(--bg-page);
  color: var(--text-primary);
  transition:
    background-color 0.3s ease,
    color 0.3s ease;
}

/* ============================================
   Tab Bar 全局样式
   ============================================ */
.t-tab-bar {
  background-color: var(--bg-card) !important;
}

/* 确保 TabBar 图标继承父元素颜色（受 --td-tab-bar-* 控制） */
.t-tab-bar .t-icon {
  color: inherit;
}

/* 强制覆盖所有情况 - 已移除 inherit，会干扰颜色设置 */

/* ============================================
   Dark Mode - CSS Variables Override
   ============================================ */
@media (prefers-color-scheme: dark) {
  page {
    /* 主色调 - 稍微提亮 */
    --primary: #5d8cf5;
    --primary-light: #7ba3f7;
    --primary-dark: #4a7cf3;
    --secondary: #9178ff;
    --secondary-light: #a892ff;

    /* 渐变 */
    --gradient-primary: linear-gradient(135deg, #5d8cf5 0%, #9178ff 100%);
    --gradient-button: linear-gradient(135deg, #5d8cf5 0%, #7ba3f7 100%);
    --gradient-subtitle: linear-gradient(
      to right,
      #5d8cf5 0%,
      #9178ff 50%,
      transparent 100%
    );

    /* 背景色 */
    --bg-page: #0d1117;
    --bg-card: #161b22;
    --bg-input: #21262d;
    --bg-elevated: #1c2128;

    /* 文字色 */
    --text-primary: #f0f6fc;
    --text-secondary: #8b949e;
    --text-muted: #6e7681;
    --text-inverse: #0d1117;

    /* 边框 */
    --border-color: #30363d;
    --border-light: #21262d;

    /* 阴影 - 深色模式使用发光效果 */
    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.5);
    --shadow-primary: 0 4px 20px rgba(93, 140, 245, 0.3);

    /* TDesign 覆盖 */
    --td-bg-color-container: var(--bg-card);
    --td-bg-color-page: var(--bg-page);
    --td-text-color-primary: var(--text-primary);
    --td-text-color-secondary: var(--text-secondary);
    --td-text-color-placeholder: var(--text-muted);
    --td-border-color: var(--border-color);
    --td-brand-color: var(--primary);
    --td-cell-bg-color: var(--bg-card);
    --td-navbar-bg-color: var(--bg-card);
    --td-tab-bar-bg-color: var(--bg-card);
    --td-tab-bar-color: var(--text-primary);
    --td-tab-bar-active-color: var(--primary);
    --td-tab-bar-item-color: var(--text-muted);
    --td-tab-bar-item-active-color: var(--primary);

    background-color: var(--bg-page);
  }

  /* TDesign Cell 组件深色适配 */
  .t-cell {
    background-color: var(--bg-card) !important;
  }

  .t-cell .t-cell__title,
  .t-cell__title-text,
  t-cell .t-cell__title {
    color: var(--text-primary) !important;
  }

  .t-cell .t-cell__note {
    color: var(--text-secondary) !important;
  }

  .t-cell .t-cell__left-icon,
  .t-cell .t-icon {
    color: var(--text-primary) !important;
  }

  /* TDesign Navbar 深色适配 */
  .t-navbar {
    background-color: var(--bg-card) !important;
    border-bottom: 1px solid var(--border-color);
  }

  .t-navbar .t-navbar__title,
  .t-navbar__title {
    color: var(--text-primary) !important;
  }

  .t-navbar .t-icon {
    color: var(--text-primary) !important;
  }

  /* TDesign Button 深色适配 */
  .t-button--primary {
    background: var(--gradient-primary) !important;
    border: none !important;
  }

  .t-button--default {
    background-color: var(--bg-input) !important;
    border-color: var(--border-color) !important;
    color: var(--text-primary) !important;
  }

  /* TDesign Collapse 深色适配 */
  .t-collapse-panel {
    background-color: var(--bg-card) !important;
  }

  .t-collapse-panel__header {
    color: var(--text-primary) !important;
  }

  /* TDesign Empty 深色适配 */
  .t-empty__description {
    color: var(--text-secondary) !important;
  }
}

/* ============================================
   通用组件样式
   ============================================ */

/* 毛玻璃效果 */
.glass-effect {
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

@media (prefers-color-scheme: dark) {
  .glass-effect {
    background: rgba(22, 27, 34, 0.85);
  }
}

/* 渐变按钮基础样式 */
.btn-gradient {
  background: var(--gradient-primary);
  color: var(--text-inverse);
  border: none;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-primary);
  transition: all 0.2s ease;
}

.btn-gradient:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 卡片基础样式 */
.card {
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  border: 1px solid var(--border-light);
}

/* 输入框样式 */
.input-field {
  background-color: var(--bg-input);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  color: var(--text-primary);
  transition:
    border-color 0.2s ease,
    box-shadow 0.2s ease;
}

.input-field:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(74, 124, 243, 0.15);
}

/* 状态标签 */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 500;
}

.badge-primary {
  background: rgba(74, 124, 243, 0.15);
  color: var(--primary);
}

.badge-success {
  background: rgba(16, 185, 129, 0.15);
  color: var(--success);
}

.badge-warning {
  background: rgba(245, 158, 11, 0.15);
  color: var(--warning);
}

.badge-danger {
  background: rgba(239, 68, 68, 0.15);
  color: var(--danger);
}

/* 分隔线 */
.divider {
  height: 1px;
  background-color: var(--border-color);
  margin: 24rpx 0;
}

/* 图标按钮 */
.icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-full);
  background-color: var(--bg-input);
  color: var(--text-secondary);
  transition: all 0.2s ease;
}

.icon-btn:active {
  background-color: var(--border-color);
  transform: scale(0.95);
}

/* ============================================
   手动主题切换支持 - JS 控制的主题类
   使用 .theme-dark 类实现手动深色模式
   ============================================ */

/* 强制浅色主题 */
.theme-light {
  /* 主色调 */
  --primary: #4a7cf3 !important;
  --primary-light: #6b93f5 !important;
  --primary-dark: #3566d9 !important;
  --secondary: #7c5cff !important;
  --secondary-light: #9178ff !important;

  /* 渐变 */
  --gradient-primary: linear-gradient(
    135deg,
    #4a7cf3 0%,
    #7c5cff 100%
  ) !important;
  --gradient-button: linear-gradient(
    135deg,
    #4a7cf3 0%,
    #6b93f5 100%
  ) !important;
  --gradient-subtitle: linear-gradient(
    to right,
    rgba(74, 124, 243, 0.1) 0%,
    rgba(124, 92, 255, 0.05) 50%,
    transparent 100%
  ) !important;

  /* 背景色 */
  --bg-page: #f5f7fa !important;
  --bg-card: #ffffff !important;
  --bg-input: #f8fafc !important;
  --bg-elevated: #ffffff !important;

  /* 文字色 */
  --text-primary: #1a1f36 !important;
  --text-secondary: #64748b !important;
  --text-muted: #94a3b8 !important;
  --text-inverse: #ffffff !important;

  /* 边框 */
  --border-color: #e2e8f0 !important;
  --border-light: #f1f5f9 !important;

  /* 阴影 */
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05) !important;
  --shadow-md:
    0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1) !important;
  --shadow-lg:
    0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1) !important;
  --shadow-primary: 0 4px 14px rgba(74, 124, 243, 0.25) !important;

  --td-tab-bar-color: var(--text-secondary) !important;
  --td-tab-bar-active-color: var(--primary) !important;

  background-color: var(--bg-page) !important;
  color: var(--text-primary) !important;
}

/* 强制深色主题 */
.theme-dark {
  /* 主色调 - 稍微提亮 */
  --primary: #5d8cf5 !important;
  --primary-light: #7ba3f7 !important;
  --primary-dark: #4a7cf3 !important;
  --secondary: #9178ff !important;
  --secondary-light: #a892ff !important;

  /* 渐变 */
  --gradient-primary: linear-gradient(
    135deg,
    #5d8cf5 0%,
    #9178ff 100%
  ) !important;
  --gradient-button: linear-gradient(
    135deg,
    #5d8cf5 0%,
    #7ba3f7 100%
  ) !important;
  --gradient-subtitle: linear-gradient(
    to right,
    rgba(93, 140, 245, 0.2) 0%,
    rgba(145, 120, 255, 0.1) 50%,
    transparent 100%
  ) !important;

  /* 背景色 */
  --bg-page: #0d1117 !important;
  --bg-card: #161b22 !important;
  --bg-input: #21262d !important;
  --bg-elevated: #1c2128 !important;

  /* 文字色 */
  --text-primary: #f0f6fc !important;
  --text-secondary: #8b949e !important;
  --text-muted: #6e7681 !important;
  --text-inverse: #0d1117 !important;

  /* 边框 */
  --border-color: #30363d !important;
  --border-light: #21262d !important;

  /* 阴影 */
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3) !important;
  --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.4) !important;
  --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.5) !important;
  --shadow-primary: 0 4px 20px rgba(93, 140, 245, 0.3) !important;

  /* TDesign 覆盖 */
  --td-bg-color-container: var(--bg-card) !important;
  --td-bg-color-page: var(--bg-page) !important;
  --td-text-color-primary: var(--text-primary) !important;
  --td-text-color-secondary: var(--text-secondary) !important;
  --td-text-color-placeholder: var(--text-muted) !important;
  --td-border-color: var(--border-color) !important;
  --td-brand-color: var(--primary) !important;
  --td-cell-bg-color: var(--bg-card) !important;
  --td-navbar-bg-color: var(--bg-card) !important;
  --td-tab-bar-bg-color: var(--bg-card) !important;
  --td-tab-bar-color: var(--text-primary) !important;
  --td-tab-bar-active-color: var(--primary) !important;
  --td-tab-bar-item-color: var(--text-muted) !important;
  --td-tab-bar-item-active-color: var(--primary) !important;

  background-color: var(--bg-page) !important;
  color: var(--text-primary) !important;
}

/* 容器包裹层，确保背景色铺满且变量穿透 */
.container-wrap {
  min-height: 100vh;
  background-color: var(--bg-page);
  color: var(--text-primary);
  transition:
    background-color 0.3s ease,
    color 0.3s ease;
  box-sizing: border-box;
}

/* 深色主题下的组件样式覆盖 */
.theme-dark .t-cell {
  background-color: var(--bg-card) !important;
  border-bottom: none !important;
}

.theme-dark .t-cell::after {
  display: none !important;
}

.theme-dark .t-cell-group .t-cell:not(:last-child)::after {
  display: none !important;
}

.theme-dark t-cell,
.theme-dark .t-cell {
  --td-cell-border-color: transparent !important;
  --td-component-stroke: transparent !important;
}

.theme-dark .t-cell--bordered::after {
  display: none !important;
}

.theme-dark .t-cell .t-cell__title,
.theme-dark .t-cell__title-text {
  color: var(--text-primary) !important;
}

.theme-dark .t-cell .t-cell__note {
  color: var(--text-secondary) !important;
}

.theme-dark .t-cell .t-cell__left-icon,
.theme-dark .t-cell .t-icon {
  color: var(--text-primary) !important;
}

.theme-dark .t-navbar {
  background-color: var(--bg-card) !important;
  border-bottom: 1px solid var(--border-color) !important;
}

.theme-dark .t-navbar .t-navbar__title,
.theme-dark .t-navbar__title,
.theme-dark .t-navbar__center-title {
  color: var(--text-primary) !important;
}

.theme-dark .t-navbar__btn,
.theme-dark .t-navbar__left-arrow {
  color: var(--text-primary) !important;
}

/* 按钮样式修正 */
/* 仅对带有 btn-gradient 类的按钮应用全局渐变，或者默认按钮 */

/* 显式定义渐变按钮类 */
.theme-dark .btn-gradient,
.theme-dark .login-btn {
  background: var(--gradient-primary) !important;
  border: none !important;
  color: #fff !important;
}

/* 确保 outline 按钮背景透明 */
.theme-dark .t-button--variant-outline {
  background: transparent !important;
  border-color: var(--primary) !important;
  color: var(--primary) !important;
}

.theme-dark .t-button--default {
  background-color: var(--bg-input) !important;
  border-color: var(--border-color) !important;
  color: var(--text-primary) !important;
}

.theme-dark .t-collapse-panel {
  background-color: var(--bg-card) !important;
}

.theme-dark .t-collapse-panel__header {
  color: var(--text-primary) !important;
}

.theme-dark .t-empty__description {
  color: var(--text-secondary) !important;
}

.theme-dark .glass-effect {
  background: rgba(22, 27, 34, 0.85) !important;
}

/* 浅色主题组件样式确保 */
.theme-light .t-cell {
  background-color: var(--bg-card) !important;
}

.theme-light .t-cell .t-cell__title,
.theme-light .t-cell__title-text {
  color: var(--text-primary) !important;
}

.theme-light .t-navbar {
  background-color: var(--bg-card) !important;
  border-bottom: 1px solid var(--border-light) !important;
}

.theme-light .t-tab-bar {
  background-color: var(--bg-card) !important;
}

/* cell渐变边框动画 */
.cell-wrapper {
  position: relative;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
}

.cell-wrapper::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 16rpx;
  padding: 4rpx;
  background: linear-gradient(135deg, #4a7cf3, #7c5cff, #4a7cf3);
  background-size: 200% 200%;
  -webkit-mask:
    linear-gradient(#fff 0 0) content-box,
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
  transition: opacity 0.2s ease;
  z-index: 1;
  pointer-events: none;
}

.cell-wrapper .t-cell {
  margin-bottom: 0 !important;
}

/* 点击时显示渐变边框 */
.cell-wrapper:active::before {
  opacity: 1;
  animation: gradient-move 1s linear infinite;
}

/* 选中状态 */
.cell-wrapper.active::before {
  opacity: 1;
  animation: gradient-move 1.5s linear infinite;
}

@keyframes gradient-move {
  0% {
    background-position: 0% 50%;
  }
  100% {
    background-position: 200% 50%;
  }
}

/* t-cell-group 容器 */
.custom-cell-group {
  margin: 0 32rpx;
}

/* 自定义 Cell 样式 */
.custom-cell {
  margin-bottom: 16rpx !important;
  border-radius: var(--radius-lg) !important;
  background-color: var(--bg-card) !important;
  box-shadow: var(--shadow-sm) !important;
  border: 1px solid var(--border-light) !important;
  overflow: hidden !important;
  transition: all 0.2s ease !important;
}

.custom-cell:active {
  transform: scale(0.995);
  box-shadow: var(--shadow-md) !important;
}

/* Cell 左侧图标 */
.custom-cell .t-cell__left-icon {
  color: var(--primary) !important;
}

/* Cell 标题 */
.custom-cell .t-cell__title {
  color: var(--text-primary) !important;
  font-weight: 500 !important;
  font-size: 32rpx !important;
}

/* Cell 描述文字 */
.custom-cell .t-cell__note {
  color: var(--text-secondary) !important;
}

/* Cell 箭头 */
.custom-cell .t-cell__right-icon {
  color: var(--text-muted) !important;
}
