<!-- 自定义tab-bar组件 -->
<view class="custom-tab-bar-container">
  <!-- 自定义指示点 -->
  <view class="custom-dots">
    <view wx:for="{{[0,1]}}" wx:for-index="index" wx:key="index" class="dot {{index === currentIndex ? 'active' : ''}}"></view>
  </view>

  <!-- 底部导航 -->
  <t-tab-bar value="{{selectedValue}}" bind:change="onTabBarChange" fixed bordered="{{false}}">
    <t-tab-bar-item value="current" icon="{{currentPageIcon}}" text="{{currentPageText}}">{{currentPageText}}</t-tab-bar-item>
    <t-tab-bar-item value="profile" icon="user" text="个人中心">个人中心</t-tab-bar-item>
  </t-tab-bar>
</view>
