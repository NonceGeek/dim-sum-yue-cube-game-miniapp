/* components/page-wrapper/index.wxss */
.page-swiper {
  width: 100%;
  height: 100vh;
}

swiper-item {
  height: 100%;
}

.scroll-content {
  height: 100%;
  width: 100%;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

/* action-sheet弹出框显示在custom-dots之上 */
t-action-sheet,
t-action-sheet .t-popup {
  z-index: 100 !important;
}

/* 个人中心预览样式 */
.game-status {
  background: var(--gradient-primary);
}

.profile-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md, 0 4px 6px rgba(0, 0, 0, 0.1));
}

.user-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding-bottom: 32rpx;
  margin-bottom: 16rpx;
}

.user-details {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-title {
  position: relative;
  display: inline-block;
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
  z-index: 0;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.user-title--animate {
  border-color: rgba(255, 255, 255, 0.9);
  box-shadow: 0 0 16rpx rgba(255, 255, 255, 0.5), inset 0 0 8rpx rgba(255, 255, 255, 0.2);
}

/* 边框跑马灯 - 使用conic-gradient旋转 */
.user-title__border {
  position: absolute;
  inset: -4rpx;
  border-radius: 10rpx;
  padding: 2rpx;
  background: conic-gradient(
    from 0deg,
    rgba(255, 255, 255, 0.3) 0%,
    rgba(255, 255, 255, 0.3) 70%,
    #fff 85%,
    rgba(255, 255, 255, 0.9) 95%,
    rgba(255, 255, 255, 0.3) 100%
  );
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
}

/* 荣誉称号扫描光 - 从左到右 */
.user-title__shine {
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0) 20%,
    rgba(255, 255, 255, 0.8) 50%,
    rgba(255, 255, 255, 0) 80%,
    transparent 100%
  );
  transform: skewX(-20deg);
}

.user-title--animate .user-title__border {
  opacity: 1;
  animation: border-rotate 1.5s linear forwards;
}

.user-title--animate .user-title__shine {
  animation: shine-sweep 0.8s ease-out forwards;
}

@keyframes border-rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

@keyframes shine-sweep {
  0% {
    left: -100%;
  }
  100% {
    left: 150%;
  }
}

/* Settings Section */
.settings-section {
  padding: 0 32rpx;
  flex: 1;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.settings-card {
  background-color: var(--bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--border-light);
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  transition: background-color 0.2s ease;
}

.setting-item:not(:last-child) {
  border-bottom: 1px solid var(--border-light);
}

.setting-item-hover {
  background-color: var(--bg-input);
}

.setting-item:active {
  background-color: var(--bg-input);
}

.setting-left {
  display: flex;
  align-items: center;
}

.setting-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.theme-icon {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #b45309;
}

.theme-dark .theme-icon {
  background: linear-gradient(135deg, #1E3A5F 0%, #2D4A6F 100%);
  color: #60A5FA;
}

.setting-label {
  font-size: 30rpx;
  color: var(--text-primary);
}

.setting-right {
  display: flex;
  align-items: center;
  color: var(--text-secondary);
}

.setting-value {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.arrow-icon {
  font-size: 32rpx;
  color: var(--text-muted);
}

/* Logout Section */
.logout-section {
  padding: 40rpx 32rpx;
  margin-top: auto;
}

.logout-btn {
  width: 100%;
  --td-button-large-height: 96rpx;
}

.t-cell {
  margin-bottom: 16rpx;
  border-bottom: none !important;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  background: var(--bg-card);
  padding: 24rpx;
  border-radius: 16rpx;
  border: 1px solid var(--border-light);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stats {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  padding: 24rpx;
  text-align: center;
  background-color: var(--bg-card);
  border: 1px solid var(--border-light);
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  min-height: 54rpx;
  line-height: 54rpx;
}

.stat-title {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}
