.page-scroll {
  height: 100%;
  width: 100%;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.preview-tip {
  padding: 32rpx;
  text-align: center;
  color: var(--text-muted);
}

.header {
  padding: 32rpx;
}

.header-option {
  background-color: var(--bg-card, #ffffff);
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  gap: 24rpx;
  box-shadow: var(--shadow-md, 0 4px 6px rgba(0, 0, 0, 0.1));
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1f36);
}

.subtitle {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  margin-top: 0;
  margin-bottom: 24rpx;
  background: var(--gradient-primary) !important;
  color: #fff;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  background: var(--bg-card);
  padding: 24rpx;
  border-radius: 16rpx;
  border: 1px solid var(--border-light);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stats {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  padding: 24rpx;
  text-align: center;
  background-color: var(--bg-card);
  border: 1px solid var(--border-light);
  border-radius: 16rpx;
  box-shadow: var(--shadow-lg);
}

.stat-card button {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  width: 100%;
  height: auto;
  line-height: inherit;
}

.stat-card button::after {
  border: none;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  min-height: 54rpx;
  line-height: 54rpx;
}

.stat-title {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}

.t-progress__canvas--inner {
  background: var(--bg-card) !important;
}

.t-progress__info {
  color: var(--text-primary) !important;
}

.t-progress__canvas--circle {
  animation: circle-breathe 2s ease-in-out infinite;
}

@keyframes circle-breathe {
  0% {
    box-shadow: 0 0 10rpx rgba(124, 92, 255, 0.3);
  }
  50% {
    box-shadow: 0 0 30rpx rgba(124, 92, 255, 0.6), 0 0 60rpx rgba(124, 92, 255, 0.3);
  }
  100% {
    box-shadow: 0 0 10rpx rgba(124, 92, 255, 0.3);
  }
}

/* 统计卡片入场动画 */
.stat-card {
  padding: 24rpx;
  text-align: center;
  background-color: var(--bg-card);
  border: 1px solid var(--border-light);
  border-radius: 16rpx;
  box-shadow: var(--shadow-lg);
  opacity: 0;
  transform: translateY(40rpx);
  animation: card-slide-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.stat-card:nth-child(1) {
  animation-delay: 0.1s;
}

.stat-card:nth-child(2) {
  animation-delay: 0.2s;
}

.stat-card:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes card-slide-in {
  0% {
    opacity: 0;
    transform: translateY(40rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 游戏列表入场动画 */
.cell-wrapper {
  opacity: 0;
  transform: translateX(-20rpx);
  animation: list-item-in 0.5s ease-out forwards;
  position: relative;
  overflow: hidden;
}

/* 彩色左侧指示条 */
.cell-wrapper::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 6rpx;
  height: 100%;
  background: linear-gradient(180deg, #5d8cf5, #9178ff);
  transform: scaleY(0);
  transform-origin: top;
  animation: bar-slide-in 0.4s ease-out forwards;
}

@keyframes list-item-in {
  0% {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes bar-slide-in {
  0% {
    transform: scaleY(0);
  }
  100% {
    transform: scaleY(1);
  }
}

.cell-wrapper:nth-child(1) { animation-delay: 0.05s; }
.cell-wrapper:nth-child(1)::before { animation-delay: 0.15s; }
.cell-wrapper:nth-child(2) { animation-delay: 0.1s; }
.cell-wrapper:nth-child(2)::before { animation-delay: 0.2s; }
.cell-wrapper:nth-child(3) { animation-delay: 0.15s; }
.cell-wrapper:nth-child(3)::before { animation-delay: 0.25s; }
.cell-wrapper:nth-child(4) { animation-delay: 0.2s; }
.cell-wrapper:nth-child(4)::before { animation-delay: 0.3s; }
.cell-wrapper:nth-child(5) { animation-delay: 0.25s; }
.cell-wrapper:nth-child(5)::before { animation-delay: 0.35s; }
.cell-wrapper:nth-child(6) { animation-delay: 0.3s; }
.cell-wrapper:nth-child(6)::before { animation-delay: 0.4s; }
