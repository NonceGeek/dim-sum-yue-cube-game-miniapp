.page-scroll {
  height: 100%;
  width: 100%;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.preview-tip {
  padding: 32rpx;
  text-align: center;
  color: var(--text-muted);
}

.header {
  padding: 32rpx;
}

.header-option {
  background-color: var(--bg-card, #ffffff);
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  gap: 24rpx;
  box-shadow: var(--shadow-md, 0 4px 6px rgba(0, 0, 0, 0.1));
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1f36);
}

.subtitle {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  margin-top: 0;
  margin-bottom: 24rpx;
  background: var(--gradient-subtitle);
}

.stats-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  background: var(--bg-card);
  padding: 24rpx;
  border-radius: 16rpx;
  border: 1px solid var(--border-light);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stats {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  padding: 24rpx;
  text-align: center;
  border: 1px solid var(--border-light);
}

.stat-card {
  padding: 24rpx;
  text-align: center;
  border: 1px solid var(--border-light);
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  min-height: 54rpx;
  line-height: 54rpx;
}

.stat-title {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}
