/* pages/question/question.wxss */
.question-page {
  min-height: 100vh;
  background-color: var(--bg-page, #f5f5f5);
  padding: 32rpx;
  padding-bottom: 200rpx;
}

/* 进度区域 */
.progress-section {
  background-color: var(--bg-card, #ffffff);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-sm);
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-text {
  font-size: 28rpx;
  color: var(--text-secondary, #666);
}

/* 题目内容 */
.question-content {
  margin-bottom: 32rpx;
}

/* 倒计时 */
.count-down {
  display: inline-flex;
  align-items: center;
}

.t-count-down {
  color: var(--text-primary) !important;
}

/* 场景标题 */
.scene-title {
  padding: 0 32rpx 24rpx 0;
  color: var(--text-primary);
  font-size: 36rpx;
  font-weight: 600;
}

/* 对话卡片 */
.dialogue-card {
  margin: 0 32rpx 32rpx;
  background: var(--bg-card);
  border-radius: 24rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--border-light);
  overflow: hidden;
}

/* 对话容器 */
.dialogue-container {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.sound-right {
  align-self: flex-end;
}

.dialogue-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.dialogue-item.left {
  flex-direction: row;
  padding-left: 16rpx;
}

.dialogue-item.right {
  flex-direction: row-reverse;
  padding-right: 16rpx;
}

.dialogue-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.dialogue-bubble {
  flex: 1;
  padding: 20rpx 32rpx;
  background: var(--bg-input);
  border-radius: 20rpx;
  max-width: 75%;
}

.dialogue-item.left .dialogue-bubble {
  border-top-left-radius: 8rpx;
}

.dialogue-item.right .dialogue-bubble {
  border-top-right-radius: 8rpx;
}

.dialogue-text {
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 提交按钮区域 */
.submit-section {
  padding: 32rpx;
}

/* 选项头像样式 */
.option-avatar {
  font-weight: 600 !important;
  color: #fff !important;
}

/* 未选中状态 - 灰色背景 */
.option-avatar {
  background-color: var(--text-muted) !important;
}

/* 选中状态 - 主题色背景 */
.option-avatar.selected {
  background-color: var(--secondary) !important;
}

.audio-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.audio-controls {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 32rpx 32rpx;
}

/* 录音按钮 */
.record-btn {
  width: 100%;
  background: var(--bg-input);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-full);
  padding: 0 20rpx;
  min-height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.2s ease;
}

.record-btn:active {
  background-color: var(--border-light);
}

.record-btn.recording {
  background: var(--success);
  border-color: var(--success);
  transform: scale(1.02);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.record-btn.recording .mic-icon {
  color: #fff !important;
}

.record-btn.recording .record-text {
  color: #fff;
}

.mic-icon {
  color: var(--text-secondary) !important;
  font-size: 32rpx;
  display: flex;
  align-items: center;
}

.record-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
}

.audio-icon {
  background: var(--primary);
  color: #fff;
  border-radius: var(--radius-full);
  padding: 12rpx;
}

.ai-button {
  background: var(--bg-card) !important;
  color: var(--text-primary) !important;
}

.btn-group {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}

/* 取消按钮 - 深色模式朦胧效果，与 record-btn 一致 */
.cancel-btn {
  background: var(--bg-input) !important;
  border: 1px solid var(--border-color) !important;
  color: var(--text-secondary) !important;
  position: relative;
  border-radius: 999px !important;
  margin-bottom: 0 !important;
}

.cancel-btn:active {
  background-color: var(--border-light) !important;
}

/* 按钮选中时渐变边框，与 scene.wxml 的 cell-wrapper 一致 */
.cancel-btn.active::before,
.ai-button.active::before {
  opacity: 1;
  animation: gradient-move 1.5s linear infinite;
  border-radius: 999px !important;
}

.image-container {
  padding: 24rpx 32rpx;
}

/* 上传占位图 */
.upload-placeholder {
  width: 100%;
  height: 33.33vh;
  background-color: var(--bg-input);
  border: 2rpx dashed var(--border-color);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.upload-placeholder:active {
  background-color: var(--border-light);
}

.upload-text {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* 图片宽度100% */
.img-full {
  width: 100% !important;
  height: 33.33vh !important;
  object-fit: cover !important;
}

.image-info {
  padding: 32rpx 32rpx 24rpx;
  color: var(--text-primary);
  font-size: 36rpx;
  font-weight: 600;
}

.count-down-container {
  display: flex;
  justify-content: center;
  padding: 0 0 24rpx;
}

.info-dialog {
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  background: var(--bg-card) !important;
}

/* 公共弹窗样式 */
.result-dialog {
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  background: var(--bg-card) !important;
}

/* 正确状态 - 渐变边框 */
.result-dialog.correct {
  position: relative;
  background: var(--gradient-subtitle) !important;
}

.result-dialog.correct::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 16rpx;
  padding: 4rpx;
  background: linear-gradient(135deg, #4a7cf3, #7c5cff, #4a7cf3);
  background-size: 200% 200%;
  -webkit-mask:
    linear-gradient(#fff 0 0) content-box,
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  animation: gradient-move 1.5s linear infinite;
  z-index: 1;
  pointer-events: none;
}

.result-dialog.correct .result-icon t-icon {
  color: var(--success);
}

.result-dialog.correct .t-dialog__header,
.result-dialog.correct .t-dialog__body-text {
  color: #fff !important;
}

/* 错误状态 */
.result-dialog.wrong .t-dialog__header {
  color: var(--text-primary) !important;
}
.result-dialog.wrong {
  color: var(--text-muted) !important;
}
.info-dialog .t-dialog__header,
.info-dialog .t-dialog__body-text {
  color: var(--text-primary) !important;
}

.info-dialog .t-button__content {
  color: var(--text-inverse) !important;
}
.info-dialog .t-dialog__button--cancel .t-button__content {
  color: var(--text-muted) !important;
}
